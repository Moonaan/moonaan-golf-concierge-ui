{
  "expo": {
    "name": "Missouri Golf Trail",
    "slug": "missouri-golf-trail",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mgt",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F2E23"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.missourigolftrail.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "We need microphone access for voice commands to the golf concierge.",
        "NSCalendarsUsageDescription": "We need calendar access to add your tee times.",
        "NSFaceIDUsageDescription": "Use Face ID to confirm bookings."
      }
    },
    "android": {
      "package": "com.missourigolftrail.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F2E23"
      },
      "permissions": [
        "RECORD_AUDIO",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "USE_BIOMETRIC",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Missouri Golf Trail to access your microphone for voice commands."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Missouri Golf Trail to add tee times to your calendar."
        }
      ]
    ],
    "experiments": {
      "tsconfigPaths": true,
      "typedRoutes": true
    }
  }
}
